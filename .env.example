# Copia este archivo a .env y reemplaza con tu API key real de TMDB.
# Conseguila gratis en: https://www.themoviedb.org/settings/api (version v3)

# --- Desarrollo local ---
# Se expone al cliente (prefijo PUBLIC_) para que `npm run dev` pueda pegarle
# directo a TMDB sin necesidad de levantar el proxy serverless.
PUBLIC_TMDB_API_KEY=tu_api_key_aqui

# --- Produccion (Vercel) ---
# NO expuesta al cliente. La usa /api/tmdb.js como proxy y la key nunca viaja
# al browser. Configurala en: Vercel > Project > Settings > Environment Variables
TMDB_API_KEY=tu_api_key_aqui
