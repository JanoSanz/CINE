---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Detalle de pelicula - CineCerca">
  <div id="movie-detail" class="movie-detail">
    <div class="loader container" role="status">
      <div class="loader__spinner" aria-hidden="true"></div>
      <p class="loader__label">Cargando detalle...</p>
    </div>
  </div>
</BaseLayout>

<style>
  .loader {
    display: flex; flex-direction: column; align-items: center;
    gap: 1rem; padding: 4rem 1rem;
  }
  .loader__spinner {
    width: 40px; height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  .loader__label { color: var(--color-text-muted); margin: 0; font-size: 0.9rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  import { getMovieDetails, getPosterUrl, getBackdropUrl } from '../scripts/api.js';
  import { getShowtimesForMovie } from '../scripts/cinemas.js';
  import { get } from '../scripts/storage.js';
  import { formatYear, formatRuntime, formatRating } from '../utils/formatters.js';
  import { isFavorite, toggleFavorite } from '../scripts/favorites.js';

  const params = new URLSearchParams(window.location.search);
  const movieId = params.get('id');
  const root = document.getElementById('movie-detail');

  const state = {
    showtimesByCinema: [],
    zone: '',
    filters: { formato: null, idioma: null, precio: null, franja: null }
  };

  const PRECIO_BUCKETS = [
    { value: 'barato',  label: 'Hasta $4000',  test: (p) => p < 4000 },
    { value: 'medio',   label: '$4000 - $5000', test: (p) => p >= 4000 && p <= 5000 },
    { value: 'premium', label: 'Más de $5000',  test: (p) => p > 5000 }
  ];

  const FRANJAS = [
    { value: 'manana', label: 'Mañana',  test: (m) => m < 13 * 60 },
    { value: 'tarde',  label: 'Tarde',   test: (m) => m >= 13 * 60 && m < 19 * 60 },
    { value: 'noche',  label: 'Noche',   test: (m) => m >= 19 * 60 }
  ];

  function toMinutes(hhmm) {
    const [h, m] = String(hhmm).split(':').map(Number);
    return h * 60 + (m || 0);
  }

  if (!movieId) {
    renderError('Falta el ID de la pelicula en la URL.');
  } else {
    loadDetail(movieId);
  }

  async function loadDetail(id) {
    try {
      state.zone = get('zona', '');
      const [movie, showtimesByCinema] = await Promise.all([
        getMovieDetails(id),
        getShowtimesForMovie(id, state.zone)
      ]);
      state.showtimesByCinema = showtimesByCinema;
      render(movie);
    } catch (err) {
      console.error(err);
      renderError(err.message || 'No pudimos cargar la pelicula.');
    }
  }

  function collectOptions(items) {
    const formatos = new Set();
    const idiomas = new Set();
    const precios = new Set();
    const franjas = new Set();

    for (const { funciones } of items) {
      for (const fn of funciones) {
        if (fn.formato) formatos.add(fn.formato);
        if (fn.idioma) idiomas.add(fn.idioma);

        const bucket = PRECIO_BUCKETS.find((b) => b.test(fn.precio));
        if (bucket) precios.add(bucket.value);

        for (const h of fn.horarios || []) {
          const min = toMinutes(h);
          const franja = FRANJAS.find((f) => f.test(min));
          if (franja) franjas.add(franja.value);
        }
      }
    }
    return {
      formatos: [...formatos],
      idiomas: [...idiomas],
      precios: PRECIO_BUCKETS.filter((b) => precios.has(b.value)),
      franjas: FRANJAS.filter((f) => franjas.has(f.value))
    };
  }

  function applyFilters(items) {
    const { formato, idioma, precio, franja } = state.filters;
    if (!formato && !idioma && !precio && !franja) return items;

    const precioBucket = precio ? PRECIO_BUCKETS.find((b) => b.value === precio) : null;
    const franjaDef = franja ? FRANJAS.find((f) => f.value === franja) : null;

    return items
      .map(({ cinema, funciones }) => ({
        cinema,
        funciones: funciones
          .filter((fn) =>
            (!formato || fn.formato === formato) &&
            (!idioma || fn.idioma === idioma) &&
            (!precioBucket || precioBucket.test(fn.precio))
          )
          .map((fn) => {
            if (!franjaDef) return fn;
            const horarios = (fn.horarios || []).filter((h) => franjaDef.test(toMinutes(h)));
            return horarios.length ? { ...fn, horarios } : null;
          })
          .filter(Boolean)
      }))
      .filter(({ funciones }) => funciones.length > 0);
  }

  function render(movie) {
    document.title = `${movie.title} - CineCerca`;
    const backdrop = getBackdropUrl(movie.backdrop_path);
    const genres = (movie.genres || []).map((g) => g.name).join(' · ');
    const fav = isFavorite(movie.id);
    const options = collectOptions(state.showtimesByCinema);

    root.innerHTML = `
      <section class="hero-movie" ${backdrop ? `style="background-image: var(--color-backdrop-overlay), url('${backdrop}');"` : ''}>
        <div class="container hero-movie__inner">
          <img class="hero-movie__poster" src="${getPosterUrl(movie.poster_path, 'w500')}" alt="Poster de ${escapeHtml(movie.title)}" />
          <div class="hero-movie__body">
            <h1>${escapeHtml(movie.title)}</h1>
            <p class="hero-movie__meta">
              ${formatYear(movie.release_date)}
              ${movie.runtime ? ` · ${formatRuntime(movie.runtime)}` : ''}
              ${genres ? ` · ${escapeHtml(genres)}` : ''}
            </p>
            ${movie.vote_average ? `<p class="hero-movie__rating">⭐ ${formatRating(movie.vote_average)} / 10</p>` : ''}
            <p class="hero-movie__overview">${escapeHtml(movie.overview || 'Sin sinopsis disponible.')}</p>
            <button id="fav-btn" class="btn ${fav ? 'btn-primary' : 'btn-ghost'}">
              ${fav ? '❤️ En favoritos' : '🤍 Agregar a favoritos'}
            </button>
          </div>
        </div>
      </section>

      <section class="container cinemas-section">
        <h2>Cines donde se proyecta ${state.zone ? `en ${escapeHtml(state.zone)}` : ''}</h2>
        ${renderFilters(options)}
        <div id="cinemas-slot">${renderCinemas(applyFilters(state.showtimesByCinema))}</div>
      </section>
    `;

    wireFavButton(movie);
    wireFilters();
  }

  function renderFilters(options) {
    const hasAny = options.formatos.length || options.idiomas.length
                || options.precios.length || options.franjas.length;
    if (!hasAny) return '';
    const { formato, idioma, precio, franja } = state.filters;

    const chip = (type, value, label, active) => `
      <button class="chip ${active ? 'chip--active' : ''}" data-filter-type="${type}" data-filter-value="${escapeHtml(value)}">
        ${escapeHtml(label)}
      </button>
    `;

    const reset = (type, active) => `
      <button class="chip ${active ? 'chip--active' : ''}" data-filter-type="${type}" data-filter-value="">Todos</button>
    `;

    return `
      <div class="filters">
        ${options.formatos.length ? `
          <div class="filters__group">
            <span class="filters__label">Formato:</span>
            ${reset('formato', !formato)}
            ${options.formatos.map((f) => chip('formato', f, f, formato === f)).join('')}
          </div>
        ` : ''}
        ${options.idiomas.length ? `
          <div class="filters__group">
            <span class="filters__label">Idioma:</span>
            ${reset('idioma', !idioma)}
            ${options.idiomas.map((i) => chip('idioma', i, i, idioma === i)).join('')}
          </div>
        ` : ''}
        ${options.precios.length ? `
          <div class="filters__group">
            <span class="filters__label">Precio:</span>
            ${reset('precio', !precio)}
            ${options.precios.map((p) => chip('precio', p.value, p.label, precio === p.value)).join('')}
          </div>
        ` : ''}
        ${options.franjas.length ? `
          <div class="filters__group">
            <span class="filters__label">Franja:</span>
            ${reset('franja', !franja)}
            ${options.franjas.map((f) => chip('franja', f.value, f.label, franja === f.value)).join('')}
          </div>
        ` : ''}
      </div>
    `;
  }

  function wireFilters() {
    document.querySelectorAll('[data-filter-type]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const type = btn.getAttribute('data-filter-type');
        const value = btn.getAttribute('data-filter-value');
        state.filters[type] = value || null;
        const slot = document.getElementById('cinemas-slot');
        slot.innerHTML = renderCinemas(applyFilters(state.showtimesByCinema));
        updateFilterChips();
      });
    });
  }

  function updateFilterChips() {
    document.querySelectorAll('[data-filter-type]').forEach((btn) => {
      const type = btn.getAttribute('data-filter-type');
      const value = btn.getAttribute('data-filter-value') || null;
      btn.classList.toggle('chip--active', state.filters[type] === value);
    });
  }

  function wireFavButton(movie) {
    const favBtn = document.getElementById('fav-btn');
    favBtn.addEventListener('click', () => {
      toggleFavorite({
        id: movie.id,
        title: movie.title,
        poster_path: movie.poster_path,
        release_date: movie.release_date,
        vote_average: movie.vote_average
      });
      const now = isFavorite(movie.id);
      favBtn.className = `btn ${now ? 'btn-primary' : 'btn-ghost'}`;
      favBtn.textContent = now ? '❤️ En favoritos' : '🤍 Agregar a favoritos';
    });
  }

  function renderCinemas(items) {
    if (!items.length) {
      return `
        <div class="empty">
          <span class="empty__icon">🏚️</span>
          <h3>Sin funciones disponibles</h3>
          <p class="text-muted">Probá ajustar los filtros o cambiar de zona desde el header.</p>
        </div>`;
    }

    return `
      <div class="cinema-list">
        ${items.map(({ cinema, funciones }) => `
          <article class="cinema-card">
            <header class="cinema-card__header">
              <div>
                <h3 class="cinema-card__name">${escapeHtml(cinema.nombre)}</h3>
                <p class="cinema-card__address">${escapeHtml(cinema.direccion)}, ${escapeHtml(cinema.ciudad)}</p>
              </div>
            </header>
            <div class="cinema-card__funciones">
              ${funciones.map((fn) => `
                <div class="funcion-row">
                  <div class="funcion-row__meta">
                    <span class="tag tag--format">${escapeHtml(fn.formato)}</span>
                    <span class="tag">${escapeHtml(fn.idioma)}</span>
                  </div>
                  <ul class="showtime-list">
                    ${fn.horarios.map((h) => `<li><span class="showtime">${escapeHtml(h)}</span></li>`).join('')}
                  </ul>
                </div>
              `).join('')}
            </div>
          </article>
        `).join('')}
      </div>
    `;
  }

  function renderError(msg) {
    root.innerHTML = `
      <div class="container">
        <div class="error-box">
          <span class="error-box__icon">⚠️</span>
          <h3>Algo salio mal</h3>
          <p class="text-muted">${escapeHtml(msg)}</p>
          <a class="btn btn-ghost" href="/">Volver al inicio</a>
        </div>
      </div>`;
  }

  function escapeHtml(str) {
    return String(str ?? '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    })[c]);
  }
</script>

<style is:global>
  .hero-movie {
    padding: 2rem 0 3rem;
    background-size: cover;
    background-position: center;
  }

  .hero-movie__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    text-align: center;
  }

  .hero-movie__poster {
    width: 220px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }

  .hero-movie__body { max-width: 700px; }
  .hero-movie__meta { color: var(--color-text-soft); margin: 0.25rem 0; }
  .hero-movie__rating { color: var(--color-accent); font-weight: 600; }
  .hero-movie__overview { color: var(--color-text-soft); line-height: 1.7; margin: 1rem 0; }

  @media (min-width: 768px) {
    .hero-movie__inner {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
    }
    .hero-movie__poster { flex-shrink: 0; }
  }

  .cinemas-section { padding: 2rem 1rem 4rem; }
  .cinemas-section h2 { margin-bottom: 1.5rem; }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .filters__group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filters__label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-right: 0.25rem;
  }

  .chip {
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    background-color: var(--color-bg-elevated);
    color: var(--color-text-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: all var(--transition-fast);
  }

  .chip:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .chip--active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .cinema-list {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cinema-list { grid-template-columns: repeat(2, 1fr); }
  }

  .cinema-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cinema-card__header { display: flex; justify-content: space-between; gap: 1rem; }
  .cinema-card__name { margin: 0 0 0.25rem 0; font-size: 1.05rem; }
  .cinema-card__address { margin: 0; color: var(--color-text-muted); font-size: 0.875rem; }

  .cinema-card__funciones { display: flex; flex-direction: column; gap: 0.75rem; }

  .funcion-row {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding-top: 0.75rem; border-top: 1px solid var(--color-border);
  }

  .funcion-row__meta { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .tag {
    display: inline-block; padding: 0.2rem 0.5rem;
    font-size: 0.75rem; font-weight: 600;
    background-color: var(--color-bg-elevated);
    color: var(--color-text-soft); border-radius: var(--radius-sm);
  }

  .tag--format { background-color: var(--color-primary); color: #fff; }

  .showtime-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }

  .showtime {
    display: inline-block; padding: 0.4rem 0.75rem;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem; font-weight: 600;
  }

  .empty {
    text-align: center; padding: 3rem 1rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.25rem;
  }
  .empty__icon { font-size: 3rem; margin-bottom: 0.5rem; }

  .error-box {
    max-width: 500px; margin: 4rem auto;
    display: flex; flex-direction: column; align-items: center;
    gap: 0.5rem; padding: 2.5rem 1rem; text-align: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .error-box__icon { font-size: 2rem; }
</style>
