---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Detalle de pelicula - CineCerca">
  <div id="movie-detail" class="movie-detail">
    <div class="loader container" role="status">
      <div class="loader__spinner" aria-hidden="true"></div>
      <p class="loader__label">Cargando detalle...</p>
    </div>
  </div>
</BaseLayout>

<style>
  .loader {
    display: flex; flex-direction: column; align-items: center;
    gap: 1rem; padding: 4rem 1rem;
  }
  .loader__spinner {
    width: 40px; height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  .loader__label { color: var(--color-text-muted); margin: 0; font-size: 0.9rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  import { getMovieDetails, getPosterUrl, getBackdropUrl } from '../scripts/api.js';
  import { getShowtimesForMovie } from '../scripts/cinemas.js';
  import { get } from '../scripts/storage.js';
  import { formatYear, formatRuntime, formatRating } from '../utils/formatters.js';
  import { isFavorite, toggleFavorite } from '../scripts/favorites.js';

  const params = new URLSearchParams(window.location.search);
  const movieId = params.get('id');
  const root = document.getElementById('movie-detail');

  if (!movieId) {
    renderError('Falta el ID de la pelicula en la URL.');
  } else {
    loadDetail(movieId);
  }

  async function loadDetail(id) {
    try {
      const zone = get('zona', '');
      const [movie, showtimesByCinema] = await Promise.all([
        getMovieDetails(id),
        getShowtimesForMovie(id, zone)
      ]);
      render(movie, showtimesByCinema, zone);
    } catch (err) {
      console.error(err);
      renderError(err.message || 'No pudimos cargar la pelicula.');
    }
  }

  function render(movie, showtimesByCinema, zone) {
    document.title = `${movie.title} - CineCerca`;
    const backdrop = getBackdropUrl(movie.backdrop_path);
    const genres = (movie.genres || []).map((g) => g.name).join(' · ');
    const fav = isFavorite(movie.id);

    root.innerHTML = `
      <section class="hero-movie" ${backdrop ? `style="background-image: linear-gradient(180deg, rgba(15,17,21,0.4), rgba(15,17,21,1)), url('${backdrop}');"` : ''}>
        <div class="container hero-movie__inner">
          <img class="hero-movie__poster" src="${getPosterUrl(movie.poster_path, 'w500')}" alt="Poster de ${escapeHtml(movie.title)}" />
          <div class="hero-movie__body">
            <h1>${escapeHtml(movie.title)}</h1>
            <p class="hero-movie__meta">
              ${formatYear(movie.release_date)}
              ${movie.runtime ? ` · ${formatRuntime(movie.runtime)}` : ''}
              ${genres ? ` · ${escapeHtml(genres)}` : ''}
            </p>
            ${movie.vote_average ? `<p class="hero-movie__rating">⭐ ${formatRating(movie.vote_average)} / 10</p>` : ''}
            <p class="hero-movie__overview">${escapeHtml(movie.overview || 'Sin sinopsis disponible.')}</p>
            <button id="fav-btn" class="btn ${fav ? 'btn-primary' : 'btn-ghost'}">
              ${fav ? '❤️ En favoritos' : '🤍 Agregar a favoritos'}
            </button>
          </div>
        </div>
      </section>

      <section class="container cinemas-section">
        <h2>Cines donde se proyecta ${zone ? `en ${escapeHtml(zone)}` : ''}</h2>
        ${renderCinemas(showtimesByCinema)}
      </section>
    `;

    const favBtn = document.getElementById('fav-btn');
    favBtn.addEventListener('click', () => {
      toggleFavorite({
        id: movie.id,
        title: movie.title,
        poster_path: movie.poster_path,
        release_date: movie.release_date,
        vote_average: movie.vote_average
      });
      const now = isFavorite(movie.id);
      favBtn.className = `btn ${now ? 'btn-primary' : 'btn-ghost'}`;
      favBtn.textContent = now ? '❤️ En favoritos' : '🤍 Agregar a favoritos';
    });
  }

  function renderCinemas(items) {
    if (!items.length) {
      return `
        <div class="empty">
          <span class="empty__icon">🏚️</span>
          <h3>Sin funciones en tu zona</h3>
          <p class="text-muted">Probá cambiando la zona desde el selector del header.</p>
        </div>`;
    }

    return `
      <div class="cinema-list">
        ${items.map(({ cinema, funciones }) => `
          <article class="cinema-card">
            <header class="cinema-card__header">
              <div>
                <h3 class="cinema-card__name">${escapeHtml(cinema.nombre)}</h3>
                <p class="cinema-card__address">${escapeHtml(cinema.direccion)}, ${escapeHtml(cinema.ciudad)}</p>
              </div>
            </header>
            <div class="cinema-card__funciones">
              ${funciones.map((fn) => `
                <div class="funcion-row">
                  <div class="funcion-row__meta">
                    <span class="tag tag--format">${escapeHtml(fn.formato)}</span>
                    <span class="tag">${escapeHtml(fn.idioma)}</span>
                  </div>
                  <ul class="showtime-list">
                    ${fn.horarios.map((h) => `<li><span class="showtime">${escapeHtml(h)}</span></li>`).join('')}
                  </ul>
                </div>
              `).join('')}
            </div>
          </article>
        `).join('')}
      </div>
    `;
  }

  function renderError(msg) {
    root.innerHTML = `
      <div class="container">
        <div class="error-box">
          <span class="error-box__icon">⚠️</span>
          <h3>Algo salio mal</h3>
          <p class="text-muted">${escapeHtml(msg)}</p>
          <a class="btn btn-ghost" href="/">Volver al inicio</a>
        </div>
      </div>`;
  }

  function escapeHtml(str) {
    return String(str ?? '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    })[c]);
  }
</script>

<style is:global>
  .hero-movie {
    padding: 2rem 0 3rem;
    background-size: cover;
    background-position: center;
  }

  .hero-movie__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    text-align: center;
  }

  .hero-movie__poster {
    width: 220px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }

  .hero-movie__body { max-width: 700px; }
  .hero-movie__meta { color: var(--color-text-soft); margin: 0.25rem 0; }
  .hero-movie__rating { color: var(--color-accent); font-weight: 600; }
  .hero-movie__overview { color: var(--color-text-soft); line-height: 1.7; margin: 1rem 0; }

  @media (min-width: 768px) {
    .hero-movie__inner {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
    }
    .hero-movie__poster { flex-shrink: 0; }
  }

  .cinemas-section { padding: 2rem 1rem 4rem; }
  .cinemas-section h2 { margin-bottom: 1.5rem; }

  .cinema-list {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cinema-list { grid-template-columns: repeat(2, 1fr); }
  }

  .cinema-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cinema-card__header { display: flex; justify-content: space-between; gap: 1rem; }
  .cinema-card__name { margin: 0 0 0.25rem 0; font-size: 1.05rem; }
  .cinema-card__address { margin: 0; color: var(--color-text-muted); font-size: 0.875rem; }

  .cinema-card__funciones { display: flex; flex-direction: column; gap: 0.75rem; }

  .funcion-row {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding-top: 0.75rem; border-top: 1px solid var(--color-border);
  }

  .funcion-row__meta { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .tag {
    display: inline-block; padding: 0.2rem 0.5rem;
    font-size: 0.75rem; font-weight: 600;
    background-color: var(--color-bg-elevated);
    color: var(--color-text-soft); border-radius: var(--radius-sm);
  }

  .tag--format { background-color: var(--color-primary); color: #fff; }

  .showtime-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }

  .showtime {
    display: inline-block; padding: 0.4rem 0.75rem;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem; font-weight: 600;
  }

  .empty {
    text-align: center; padding: 3rem 1rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.25rem;
  }
  .empty__icon { font-size: 3rem; margin-bottom: 0.5rem; }

  .error-box {
    max-width: 500px; margin: 4rem auto;
    display: flex; flex-direction: column; align-items: center;
    gap: 0.5rem; padding: 2.5rem 1rem; text-align: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .error-box__icon { font-size: 2rem; }
</style>
