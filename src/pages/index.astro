---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import Loader from '../components/Loader.astro';
---

<BaseLayout title="CineCerca - Busca peliculas en cines cercanos">
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__content">
      <span class="hero__eyebrow">
        <span class="hero__pulse"></span>
        Cartelera actualizada
      </span>
      <h1 class="hero__title">
        Encontra la pelicula perfecta
        <span class="hero__title-accent">cerca tuyo</span>
      </h1>
      <p class="hero__subtitle">
        Busca un titulo y descubri en que cines de tu zona se proyecta, con horarios, formato e idioma.
      </p>
      <div class="hero__search">
        <SearchBar autofocus />
      </div>
      <ul class="hero__badges" aria-label="Caracteristicas">
        <li><span class="hero__badge-icon">🎬</span> 10+ cines en AR</li>
        <li><span class="hero__badge-icon">⚡</span> Resultados al instante</li>
        <li><span class="hero__badge-icon">📍</span> Geolocalizacion opcional</li>
      </ul>
    </div>
  </section>

  <section class="trending container" id="trending">
    <header class="section-head">
      <div>
        <span class="section-eyebrow">🔥 En tendencia</span>
        <h2 class="section-title">Lo mas visto esta semana</h2>
      </div>
      <a class="section-action" href="/buscar">Ver todas →</a>
    </header>
    <div id="trending-slot">
      <Loader label="Cargando tendencias..." />
    </div>
  </section>

  <section class="how-it-works container">
    <header class="section-head section-head--center">
      <span class="section-eyebrow">Asi funciona</span>
      <h2 class="section-title">En 3 pasos estas en el cine</h2>
    </header>
    <ol class="steps">
      <li class="step">
        <span class="step__num">1</span>
        <h3 class="step__title">Busca la pelicula</h3>
        <p class="step__desc">Escribi el titulo y obtene resultados en tiempo real desde TMDB.</p>
      </li>
      <li class="step">
        <span class="step__num">2</span>
        <h3 class="step__title">Elegi tu zona</h3>
        <p class="step__desc">Selecciona tu zona o activa la geolocalizacion para ordenar por cercania.</p>
      </li>
      <li class="step">
        <span class="step__num">3</span>
        <h3 class="step__title">Ve los horarios</h3>
        <p class="step__desc">Revisa las funciones disponibles, formato e idioma, y elegi la que te queda mejor.</p>
      </li>
    </ol>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: 4rem 0 3rem;
    text-align: center;
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(229, 9, 20, 0.25), transparent 70%),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(245, 197, 24, 0.08), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-soft);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .hero__pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-primary);
    box-shadow: 0 0 0 0 rgba(229, 9, 20, 0.5);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(229, 9, 20, 0.5); }
    70% { box-shadow: 0 0 0 10px rgba(229, 9, 20, 0); }
    100% { box-shadow: 0 0 0 0 rgba(229, 9, 20, 0); }
  }

  .hero__title {
    font-size: clamp(2rem, 6vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0;
    max-width: 900px;
  }

  .hero__title-accent {
    display: inline-block;
    background: linear-gradient(135deg, var(--color-primary), #ff4a52);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero__subtitle {
    color: var(--color-text-soft);
    max-width: 620px;
    margin: 0 auto;
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
  }

  .hero__search {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 1rem;
    margin-top: 0.5rem;
  }

  .hero__badges {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .hero__badges li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .hero__badge-icon {
    font-size: 1rem;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .section-head--center {
    justify-content: center;
    text-align: center;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .section-title {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
  }

  .section-action {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .section-action:hover { color: var(--color-primary); }

  .trending { padding: 2rem 1rem 3rem; }

  .how-it-works {
    padding: 3rem 1rem 4rem;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .steps { grid-template-columns: repeat(3, 1fr); }
  }

  .step {
    position: relative;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem 1.5rem;
    transition: transform var(--transition-base), border-color var(--transition-base);
  }

  .step:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
  }

  .step__num {
    position: absolute;
    top: -16px;
    left: 24px;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), #ff4a52);
    color: #fff;
    font-weight: 800;
    font-size: 0.95rem;
    box-shadow: 0 4px 14px rgba(229, 9, 20, 0.35);
  }

  .step__title {
    margin: 0.75rem 0 0.5rem;
    font-size: 1.1rem;
  }

  .step__desc {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.925rem;
    line-height: 1.55;
  }
</style>

<script>
  import { getTrending, getPosterUrl } from '../scripts/api.js';
  import { formatYear, formatRating } from '../utils/formatters.js';
  import { isFavorite, toggleFavorite } from '../scripts/favorites.js';

  const slot = document.getElementById('trending-slot');

  function renderError(msg) {
    slot.innerHTML = `
      <div class="error-inline">
        <p>⚠️ ${msg}</p>
        <button class="btn btn-ghost" onclick="location.reload()">Reintentar</button>
      </div>`;
  }

  function renderMovies(movies) {
    const grid = document.createElement('div');
    grid.className = 'movie-grid';
    grid.innerHTML = movies.map((m) => `
      <article class="movie-card" data-id="${m.id}">
        <a href="/pelicula?id=${m.id}" class="movie-card__link">
          <div class="movie-card__poster">
            <img src="${getPosterUrl(m.poster_path, 'w342')}" alt="Poster de ${m.title}" loading="lazy" />
            ${m.vote_average ? `<span class="movie-card__rating">⭐ ${formatRating(m.vote_average)}</span>` : ''}
          </div>
          <div class="movie-card__body">
            <h3 class="movie-card__title">${m.title}</h3>
            <p class="movie-card__year">${formatYear(m.release_date)}</p>
          </div>
        </a>
        <button class="movie-card__fav" data-fav-btn data-movie-id="${m.id}" aria-label="Favorito">
          <span data-fav-icon>${isFavorite(m.id) ? '❤️' : '🤍'}</span>
        </button>
      </article>
    `).join('');

    slot.innerHTML = '';
    slot.appendChild(grid);
    wireFavorites(movies);
  }

  function wireFavorites(movies) {
    document.querySelectorAll('[data-fav-btn]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = Number(btn.getAttribute('data-movie-id'));
        const movie = movies.find((m) => Number(m.id) === id);
        if (!movie) return;
        toggleFavorite(movie);
        const icon = btn.querySelector('[data-fav-icon]');
        icon.textContent = isFavorite(id) ? '❤️' : '🤍';
      });
    });
  }

  getTrending()
    .then((data) => {
      if (!data.results?.length) {
        slot.innerHTML = '<p class="text-muted">No hay tendencias disponibles.</p>';
        return;
      }
      renderMovies(data.results.slice(0, 10));
    })
    .catch((err) => {
      console.error(err);
      renderError(err.message || 'No pudimos cargar las tendencias.');
    });
</script>

<style is:global>
  .movie-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 560px) { .movie-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 900px) { .movie-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1200px) { .movie-grid { grid-template-columns: repeat(5, 1fr); } }

  .movie-card {
    position: relative;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    border: 1px solid var(--color-border);
  }
  .movie-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }
  .movie-card__link { display: block; color: inherit; }
  .movie-card__poster { position: relative; aspect-ratio: 2/3; background-color: var(--color-bg-elevated); overflow: hidden; }
  .movie-card__poster img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 600ms ease;
  }
  .movie-card:hover .movie-card__poster img { transform: scale(1.05); }
  .movie-card__rating {
    position: absolute; top: 0.5rem; left: 0.5rem;
    background-color: rgba(0,0,0,0.75); color: var(--color-accent);
    font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    backdrop-filter: blur(4px);
  }
  .movie-card__body { padding: 0.75rem; }
  .movie-card__title {
    font-size: 0.95rem; font-weight: 600; margin: 0 0 0.25rem 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .movie-card__year { font-size: 0.8rem; color: var(--color-text-muted); margin: 0; }
  .movie-card__fav {
    position: absolute; top: 0.5rem; right: 0.5rem;
    background-color: rgba(0,0,0,0.7); border-radius: 999px;
    width: 36px; height: 36px; display: grid; place-items: center;
    font-size: 1.1rem;
    backdrop-filter: blur(4px);
    transition: transform var(--transition-fast);
  }
  .movie-card__fav:hover { transform: scale(1.1); }

  .error-inline {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-text-muted);
  }
</style>
