---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cines - CineCerca">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

  <div class="container page">
    <h1 class="page-title">Cines</h1>
    <p class="text-muted page-sub">Listado de cines disponibles. Usa el selector de zona en el header para filtrar.</p>

    <div class="actions">
      <button id="geo-btn" class="btn btn-ghost">📍 Ordenar por cercania</button>
    </div>

    <div id="map" class="cines-map" aria-label="Mapa de cines"></div>

    <div id="cinemas-slot">
      <div class="loader" role="status">
        <div class="loader__spinner" aria-hidden="true"></div>
        <p class="loader__label">Cargando cines...</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-sub { margin-bottom: 1.5rem; }
  .actions { margin-bottom: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .cines-map {
    height: 360px;
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin-bottom: 2rem;
    background-color: var(--color-surface);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .cines-map { height: 420px; }
  }

  .loader {
    display: flex; flex-direction: column; align-items: center;
    gap: 1rem; padding: 3rem 1rem;
  }
  .loader__spinner {
    width: 40px; height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  .loader__label { color: var(--color-text-muted); margin: 0; font-size: 0.9rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  import { getCinemasByZone } from '../scripts/cinemas.js';
  import { get } from '../scripts/storage.js';
  import { getUserPosition, sortByDistance } from '../scripts/geolocation.js';
  import { formatDistance } from '../utils/formatters.js';

  const slot = document.getElementById('cinemas-slot');
  const geoBtn = document.getElementById('geo-btn');
  const mapEl = document.getElementById('map');

  let currentCinemas = [];
  let userPos = null;
  let map = null;
  let markerLayer = null;
  let tileLayer = null;

  const TILES = {
    dark: {
      url: 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
      attribution: '&copy; OpenStreetMap &copy; CARTO'
    },
    light: {
      url: 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
      attribution: '&copy; OpenStreetMap &copy; CARTO'
    }
  };

  function escapeHtml(str) {
    return String(str ?? '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    })[c]);
  }

  function currentTheme() {
    return document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
  }

  async function ensureLeaflet() {
    if (window.L) return window.L;
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.crossOrigin = '';
      script.onload = () => resolve(window.L);
      script.onerror = () => reject(new Error('No se pudo cargar Leaflet.'));
      document.head.appendChild(script);
    });
  }

  async function initMap() {
    const L = await ensureLeaflet();
    if (map) return;

    map = L.map(mapEl, { scrollWheelZoom: false }).setView([-34.6037, -58.3816], 11);
    const theme = currentTheme();
    tileLayer = L.tileLayer(TILES[theme].url, {
      attribution: TILES[theme].attribution,
      maxZoom: 19
    }).addTo(map);
    markerLayer = L.layerGroup().addTo(map);

    window.addEventListener('theme:change', swapTiles);
    const observer = new MutationObserver(swapTiles);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }

  function swapTiles() {
    if (!map || !tileLayer) return;
    const theme = currentTheme();
    map.removeLayer(tileLayer);
    tileLayer = window.L.tileLayer(TILES[theme].url, {
      attribution: TILES[theme].attribution,
      maxZoom: 19
    }).addTo(map);
  }

  function drawMarkers(cinemas) {
    if (!map || !markerLayer) return;
    const L = window.L;
    markerLayer.clearLayers();

    if (!cinemas.length) return;

    const bounds = [];
    for (const c of cinemas) {
      if (!c.coordenadas) continue;
      const { lat, lng } = c.coordenadas;
      const marker = L.marker([lat, lng]).addTo(markerLayer);
      marker.bindPopup(`
        <strong>${escapeHtml(c.nombre)}</strong><br/>
        <small>${escapeHtml(c.direccion)}</small><br/>
        <small>${escapeHtml(c.ciudad)} · ${escapeHtml(c.zona)}</small>
      `);
      bounds.push([lat, lng]);
    }

    if (bounds.length === 1) {
      map.setView(bounds[0], 14);
    } else if (bounds.length > 1) {
      map.fitBounds(bounds, { padding: [30, 30] });
    }
  }

  function render(cinemas) {
    drawMarkers(cinemas);

    if (!cinemas.length) {
      slot.innerHTML = `
        <div class="empty">
          <span class="empty__icon">🏚️</span>
          <h3>No hay cines en esta zona</h3>
          <p class="text-muted">Probá cambiando la zona desde el header.</p>
        </div>`;
      return;
    }

    slot.innerHTML = `
      <div class="cinema-list">
        ${cinemas.map((c) => `
          <article class="cinema-card">
            <header class="cinema-card__header">
              <div>
                <h3 class="cinema-card__name">${escapeHtml(c.nombre)}</h3>
                <p class="cinema-card__address">${escapeHtml(c.direccion)}, ${escapeHtml(c.ciudad)}</p>
                <p class="cinema-card__zone text-muted">Zona: ${escapeHtml(c.zona)} · ${c.salas} salas</p>
              </div>
              ${c.distanceKm != null ? `<span class="cinema-card__distance">📍 ${formatDistance(c.distanceKm)}</span>` : ''}
            </header>
            ${c.telefono ? `<p class="text-muted">📞 ${escapeHtml(c.telefono)}</p>` : ''}
          </article>
        `).join('')}
      </div>
    `;
  }

  async function load() {
    try {
      const zone = get('zona', '');
      currentCinemas = await getCinemasByZone(zone);
      if (userPos) currentCinemas = sortByDistance(currentCinemas, userPos);
      render(currentCinemas);
    } catch (err) {
      console.error(err);
      slot.innerHTML = `
        <div class="error-box">
          <p>⚠️ No pudimos cargar los cines.</p>
          <button class="btn btn-ghost" onclick="location.reload()">Reintentar</button>
        </div>`;
    }
  }

  geoBtn.addEventListener('click', async () => {
    geoBtn.disabled = true;
    geoBtn.textContent = '📍 Obteniendo ubicacion...';
    try {
      userPos = await getUserPosition();
      currentCinemas = sortByDistance(currentCinemas, userPos);
      render(currentCinemas);
      geoBtn.textContent = '📍 Ordenado por cercania';
    } catch (err) {
      console.error(err);
      geoBtn.textContent = '📍 No pudimos acceder a tu ubicacion';
      setTimeout(() => { geoBtn.disabled = false; geoBtn.textContent = '📍 Ordenar por cercania'; }, 2500);
    }
  });

  window.addEventListener('zone:change', load);

  initMap().then(load).catch((err) => {
    console.error(err);
    mapEl.remove();
    load();
  });
</script>

<style is:global>
  .cinema-list {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .cinema-list { grid-template-columns: repeat(2, 1fr); }
  }

  .cinema-card__zone { margin: 0.25rem 0 0 0; font-size: 0.8rem; }
  .cinema-card__distance {
    font-size: 0.8rem;
    color: var(--color-text-soft);
    white-space: nowrap;
    background-color: var(--color-bg-elevated);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    height: fit-content;
  }

  .leaflet-popup-content {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .leaflet-popup-content strong { color: #111; }
</style>
