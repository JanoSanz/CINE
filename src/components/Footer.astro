---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <p>&copy; {year} CineCerca &middot; Proyecto de portfolio.</p>
    <p class="text-muted">Datos de peliculas provistos por <a href="https://www.themoviedb.org/" target="_blank" rel="noopener">TMDB</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    background-color: var(--color-bg-elevated);
    margin-top: 3rem;
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: center;
    font-size: 0.875rem;
  }

  .site-footer__inner p { margin: 0; }

  @media (min-width: 768px) {
    .site-footer__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>