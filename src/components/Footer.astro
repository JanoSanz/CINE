---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__accent" aria-hidden="true"></div>

  <div class="container site-footer__top">
    <div class="site-footer__brand">
      <div class="site-footer__logo" aria-hidden="true">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="9" width="26" height="18" rx="3" fill="currentColor" opacity="0.15"/>
          <rect x="3" y="9" width="26" height="18" rx="3" stroke="currentColor" stroke-width="2"/>
          <circle cx="8" cy="6" r="2" fill="currentColor"/>
          <circle cx="14" cy="6" r="2" fill="currentColor"/>
          <circle cx="20" cy="6" r="2" fill="currentColor"/>
          <circle cx="26" cy="6" r="2" fill="currentColor"/>
          <path d="M14 14 L14 22 L22 18 Z" fill="currentColor"/>
        </svg>
      </div>
      <div>
        <p class="site-footer__name">Cine<span class="site-footer__accent-text">Cerca</span></p>
        <p class="site-footer__tagline">Encontra donde ver tu pelicula favorita, rapido y sin vueltas.</p>
      </div>
    </div>

    <nav class="site-footer__nav" aria-label="Navegacion del pie">
      <div class="site-footer__col">
        <h4 class="site-footer__heading">Explorar</h4>
        <ul>
          <li><a href="/">Inicio</a></li>
          <li><a href="/cines">Cines</a></li>
          <li><a href="/favoritos">Favoritos</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">Recursos</h4>
        <ul>
          <li><a href="https://www.themoviedb.org/" target="_blank" rel="noopener">TMDB</a></li>
          <li><a href="https://docs.astro.build/" target="_blank" rel="noopener">Astro docs</a></li>
          <li><a href="https://leafletjs.com/" target="_blank" rel="noopener">Leaflet</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">Proyecto</h4>
        <ul>
          <li><a href="https://github.com/JanoSanz" target="_blank" rel="noopener">GitHub</a></li>
          <li>
            <button
              type="button"
              class="site-footer__contact"
              data-copy-email="janosanz04@gmail.com"
              aria-label="Copiar email de contacto"
            >
              <span data-copy-label>Contacto</span>
            </button>
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="container site-footer__bottom">
    <p>&copy; {year} CineCerca. Proyecto de portfolio.</p>
    <p class="site-footer__credits">
      Hecho con <span class="site-footer__heart" aria-hidden="true">♥</span> usando Astro
      &middot; Datos de <a href="https://www.themoviedb.org/" target="_blank" rel="noopener">TMDB</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: 4rem;
    padding: 3rem 0 1.5rem;
    background-color: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-soft);
    font-size: 0.9rem;
  }

  .site-footer__accent {
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary) 50%, transparent);
    opacity: 0.5;
  }

  .site-footer__top {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .site-footer__brand {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    max-width: 340px;
  }

  .site-footer__logo {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-primary), #ff4a52);
    color: #fff;
    box-shadow: 0 4px 14px rgba(229, 9, 20, 0.35);
    flex-shrink: 0;
  }

  .site-footer__logo svg {
    width: 22px;
    height: 22px;
  }

  .site-footer__name {
    margin: 0 0 0.2rem;
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .site-footer__accent-text {
    color: var(--color-primary);
  }

  .site-footer__tagline {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .site-footer__nav {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
  }

  .site-footer__heading {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .site-footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .site-footer__col a {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: color var(--transition-fast), transform var(--transition-fast);
    display: inline-block;
  }

  .site-footer__col a:hover {
    color: var(--color-primary);
    transform: translateX(2px);
  }

  .site-footer__contact {
    padding: 0;
    font: inherit;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    background: none;
    border: none;
    text-align: left;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .site-footer__contact:hover {
    color: var(--color-primary);
    transform: translateX(2px);
  }

  .site-footer__contact.is-copied {
    color: var(--color-success);
  }

  .site-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .site-footer__bottom p { margin: 0; }

  .site-footer__credits a {
    color: var(--color-text-soft);
    font-weight: 500;
  }

  .site-footer__credits a:hover { color: var(--color-primary); }

  .site-footer__heart {
    color: var(--color-primary);
    display: inline-block;
    animation: heartbeat 1.8s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 40%, 100% { transform: scale(1); }
    20% { transform: scale(1.15); }
  }

  @media (min-width: 640px) {
    .site-footer__nav { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 768px) {
    .site-footer {
      padding-top: 4rem;
    }

    .site-footer__top {
      grid-template-columns: 1.2fr 2fr;
      align-items: start;
      gap: 3rem;
    }

    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>

<script>
  import { showToast } from '../scripts/toast.js';

  async function copyToClipboard(text) {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
  }

  document.querySelectorAll('[data-copy-email]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const email = btn.getAttribute('data-copy-email');
      try {
        await copyToClipboard(email);
        showToast(`✓ Email copiado: ${email}`, { duration: 3000, variant: 'success' });
      } catch (err) {
        console.error(err);
        showToast('No pudimos copiar el email. Intentalo de nuevo.', { variant: 'error' });
      }
    });
  });
</script>
