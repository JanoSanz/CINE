---
import { formatYear, formatRating } from '../utils/formatters.js';
import { getPosterUrl } from '../scripts/api.js';

const { movie } = Astro.props;
const poster = getPosterUrl(movie.poster_path, 'w342');
const year = formatYear(movie.release_date);
const rating = formatRating(movie.vote_average);
---

<article class="movie-card" data-id={movie.id}>
  <a href={`/pelicula?id=${movie.id}`} class="movie-card__link" aria-label={`Ver detalle de ${movie.title}`}>
    <div class="movie-card__poster">
      <img
        src={poster}
        alt={`Poster de ${movie.title}`}
        loading="lazy"
        width="342"
        height="513"
      />
      {rating && (
        <span class="movie-card__rating" title="Rating TMDB">
          ⭐ {rating}
        </span>
      )}
    </div>
    <div class="movie-card__body">
      <h3 class="movie-card__title">{movie.title}</h3>
      {year && <p class="movie-card__year">{year}</p>}
    </div>
  </a>
  <button
    class="movie-card__fav"
    data-fav-btn
    data-movie-id={movie.id}
    aria-label={`Marcar ${movie.title} como favorito`}
  >
    <span data-fav-icon>🤍</span>
  </button>
</article>

<style>
  .movie-card {
    position: relative;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    border: 1px solid var(--color-border);
  }

  .movie-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .movie-card__link {
    display: block;
    color: inherit;
  }

  .movie-card__link:hover { color: inherit; }

  .movie-card__poster {
    position: relative;
    aspect-ratio: 2 / 3;
    background-color: var(--color-bg-elevated);
  }

  .movie-card__poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .movie-card__rating {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    background-color: rgba(0, 0, 0, 0.75);
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  .movie-card__body { padding: 0.75rem; }

  .movie-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .movie-card__year {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .movie-card__fav {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background-color: rgba(0, 0, 0, 0.7);
    border-radius: 999px;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    font-size: 1.1rem;
    transition: transform var(--transition-fast);
  }

  .movie-card__fav:hover { transform: scale(1.1); }
</style>

<script>
  import { isFavorite, toggleFavorite } from '../scripts/favorites.js';

  function syncIcon(btn) {
    const id = btn.getAttribute('data-movie-id');
    const icon = btn.querySelector('[data-fav-icon]');
    icon.textContent = isFavorite(id) ? '❤️' : '🤍';
  }

  document.querySelectorAll('[data-fav-btn]').forEach((btn) => {
    syncIcon(btn);
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest('.movie-card');
      const id = Number(btn.getAttribute('data-movie-id'));
      const titleEl = card.querySelector('.movie-card__title');
      const imgEl = card.querySelector('img');
      const yearEl = card.querySelector('.movie-card__year');
      const ratingEl = card.querySelector('.movie-card__rating');

      toggleFavorite({
        id,
        title: titleEl?.textContent || '',
        poster_path: imgEl?.src.split('/').slice(-1)[0]
          ? '/' + imgEl.src.split('/').slice(-1)[0]
          : null,
        release_date: yearEl?.textContent ? `${yearEl.textContent}-01-01` : null,
        vote_average: ratingEl ? parseFloat(ratingEl.textContent.replace('⭐', '').trim()) : null
      });
      syncIcon(btn);
    });
  });
</script>