---
import ZoneSelector from './ZoneSelector.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Ir al inicio">
      <span class="brand__icon" aria-hidden="true">🎬</span>
      <span class="brand__name">CineCerca</span>
    </a>

    <nav class="nav" aria-label="Navegacion principal">
      <a href="/" class="nav__link">Inicio</a>
      <a href="/cines" class="nav__link">Cines</a>
      <a href="/favoritos" class="nav__link">Favoritos</a>
    </nav>

    <div class="site-header__right">
      <ZoneSelector />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-header-bg);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-height);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 100%;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
  }

  .brand__icon { font-size: 1.5rem; }

  .nav {
    display: none;
    gap: 1.25rem;
  }

  .nav__link {
    color: var(--color-text-soft);
    font-weight: 500;
  }

  .nav__link:hover { color: var(--color-text); }

  .site-header__right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .nav { display: flex; }
  }
</style>