---

<label class="zone-selector">
  <span class="sr-only">Zona</span>
  <select id="zone-selector" aria-label="Seleccionar zona">
    <option value="">Todas las zonas</option>
  </select>
</label>

<style>
  .zone-selector select {
    background-color: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    min-width: 150px;
    cursor: pointer;
  }
</style>

<script>
  import { getZones } from '../scripts/cinemas.js';
  import { get, set } from '../scripts/storage.js';

  const KEY = 'zona';
  const select = document.getElementById('zone-selector');
  if (!select) throw new Error('zone-selector no encontrado');

  const saved = get(KEY, '');

  getZones().then((zones) => {
    for (const zone of zones) {
      const option = document.createElement('option');
      option.value = zone;
      option.textContent = zone;
      if (zone === saved) option.selected = true;
      select.appendChild(option);
    }
  });

  select.addEventListener('change', (e) => {
    const value = e.target.value;
    set(KEY, value);
    window.dispatchEvent(new CustomEvent('zone:change', { detail: value }));
  });
</script>